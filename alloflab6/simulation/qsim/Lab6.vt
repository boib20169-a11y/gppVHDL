module modifiedalucore_gpp_vlg_vec_tst();
// constants                                           
// general purpose registers
reg [7:0] A;
reg [7:0] B;
reg Clock;
reg data_in;
reg Enable_decoder;
reg FSM_reset;
reg Reset_A;
reg Reset_B;
// wires                                               
wire [0:6] neg;
wire [0:6] r_first_four;
wire [0:6] r_last_four;
wire [0:6] student_id;

wire sampler;                             

// assign statements (if any)                          
modifiedalucore_gpp i1 (
// port map - connection between master ports and signals/registers   
	.A(A),
	.B(B),
	.Clock(Clock),
	.data_in(data_in),
	.Enable_decoder(Enable_decoder),
	.FSM_reset(FSM_reset),
	.neg(neg),
	.r_first_four(r_first_four),
	.r_last_four(r_last_four),
	.Reset_A(Reset_A),
	.Reset_B(Reset_B),
	.student_id(student_id)
);
// A[ 7 ]
initial
begin
	A[7] = 1'b0;
end 
// A[ 6 ]
initial
begin
	A[6] = 1'b1;
end 
// A[ 5 ]
initial
begin
	A[5] = 1'b0;
end 
// A[ 4 ]
initial
begin
	A[4] = 1'b0;
end 
// A[ 3 ]
initial
begin
	A[3] = 1'b0;
end 
// A[ 2 ]
initial
begin
	A[2] = 1'b0;
end 
// A[ 1 ]
initial
begin
	A[1] = 1'b1;
end 
// A[ 0 ]
initial
begin
	A[0] = 1'b0;
end 
// B[ 7 ]
initial
begin
	B[7] = 1'b0;
end 
// B[ 6 ]
initial
begin
	B[6] = 1'b1;
end 
// B[ 5 ]
initial
begin
	B[5] = 1'b0;
end 
// B[ 4 ]
initial
begin
	B[4] = 1'b1;
end 
// B[ 3 ]
initial
begin
	B[3] = 1'b0;
end 
// B[ 2 ]
initial
begin
	B[2] = 1'b0;
end 
// B[ 1 ]
initial
begin
	B[1] = 1'b0;
end 
// B[ 0 ]
initial
begin
	B[0] = 1'b1;
end 

// Clock
always
begin
	Clock = 1'b0;
	Clock = #50000 1'b1;
	#50000;
end 

// data_in
initial
begin
	data_in = 1'b1;
end 

// Enable_decoder
initial
begin
	Enable_decoder = 1'b1;
end 

// FSM_reset
initial
begin
	FSM_reset = 1'b0;
end 

// Reset_A
initial
begin
	Reset_A = 1'b0;
end 

// Reset_B
initial
begin
	Reset_B = 1'b0;
end 

modifiedalucore_gpp_vlg_sample_tst tb_sample (
	.A(A),
	.B(B),
	.Clock(Clock),
	.data_in(data_in),
	.Enable_decoder(Enable_decoder),
	.FSM_reset(FSM_reset),
	.Reset_A(Reset_A),
	.Reset_B(Reset_B),
	.sampler_tx(sampler)
);

modifiedalucore_gpp_vlg_check_tst tb_out(
	.neg(neg),
	.r_first_four(r_first_four),
	.r_last_four(r_last_four),
	.student_id(student_id),
	.sampler_rx(sampler)
);
endmodule

