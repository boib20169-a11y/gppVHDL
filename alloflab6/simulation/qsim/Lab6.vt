always @(neg_expected or neg or r_first_four_expected or r_first_four or r_last_four_expected or r_last_four or student_id_expected or student_id)
begin
	trigger <= ~trigger;
end

always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected neg = %b | expected r_first_four = %b | expected r_last_four = %b | expected student_id = %b | ",neg_expected_prev,r_first_four_expected_prev,r_last_four_expected_prev,student_id_expected_prev);
	$display("| real neg = %b | real r_first_four = %b | real r_last_four = %b | real student_id = %b | ",neg_prev,r_first_four_prev,r_last_four_prev,student_id_prev);
`endif
	if (
		( r_first_four_expected_prev[0] !== 1'bx ) && ( r_first_four_prev[0] !== r_first_four_expected_prev[0] )
		&& ((r_first_four_expected_prev[0] !== last_r_first_four_exp[0]) ||
			on_first_change[2])
	)
	begin
